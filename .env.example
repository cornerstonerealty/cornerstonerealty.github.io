# Rental Application Form - Environment Configuration

# Recipient email address (where applications will be sent)
TO_EMAIL=your-email@example.com

# Sender email address (from address)
FROM_EMAIL=noreply@example.com

# Sender name
FROM_NAME=Rental Application Form

# SMTP Configuration (Optional - if not set, PHP mail() will be used)
# For Gmail: smtp.gmail.com
# For Outlook: smtp-mail.outlook.com
# For Yahoo: smtp.mail.yahoo.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_ENCRYPTION=tls

# Note: For Gmail, you need to use an App Password, not your regular password
# Generate one at: https://myaccount.google.com/apppasswords
